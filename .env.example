# Copy this file to .env (or .env.local) and tweak values for your shell.
# Both files are gitignored.

# When the agent finishes detecting tags on a page, do we auto-start
# visualization generation for every tag in parallel ("true", production
# behavior — the user always sees something) or do we wait for the user
# to click a tag before spending tokens on it ("false", dev behavior)?
#
# Default if unset: "true". Setting to anything other than "false" is
# treated as auto.
NEXT_PUBLIC_AUTO_GENERATE_VIZ=true
